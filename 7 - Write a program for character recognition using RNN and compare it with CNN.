import tensorflow as tf
from tensorflow.keras import layers, models

# Load MNIST
(x_train,y_train),(x_test,y_test) = tf.keras.datasets.mnist.load_data()
x_train, x_test = x_train/255.0, x_test/255.0

# RNN model (treats each row as a timestep)
rnn = models.Sequential([
    layers.SimpleRNN(128, input_shape=(28,28)),
    layers.Dense(10, activation='softmax')
])
rnn.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
print("Training RNN...")
rnn.fit(x_train, y_train, epochs=3, verbose=1)
_, rnn_acc = rnn.evaluate(x_test, y_test, verbose=0)

# CNN model
cnn = models.Sequential([
    layers.Conv2D(32, (3,3), activation='relu', input_shape=(28,28,1)),
    layers.MaxPooling2D(2,2),
    layers.Flatten(),
    layers.Dense(128, activation='relu'),
    layers.Dense(10, activation='softmax')
])
cnn.compile(optimizer='adam', loss='sparse_categorical_crossentropy', metrics=['accuracy'])
print("\nTraining CNN...")
cnn.fit(x_train[...,None], y_train, epochs=3, verbose=1)
_, cnn_acc = cnn.evaluate(x_test[...,None], y_test, verbose=0)

print(f"\n--- Comparison ---")
print(f"RNN Accuracy: {rnn_acc:.4f}")
print(f"CNN Accuracy: {cnn_acc:.4f}")
print("CNN performs better." if cnn_acc > rnn_acc else "RNN performs better.")
